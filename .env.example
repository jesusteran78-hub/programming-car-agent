OPENAI_API_KEY=sk-proj-...
WHAPI_TOKEN=TU_TOKEN_DE_WHAPI_AQUI
PORT=3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Google Calendar Integration
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create a project or select existing
# 3. Enable "Google Calendar API"
# 4. Create Service Account credentials
# 5. Download JSON key and extract values below
# 6. In Google Workspace Admin, share calendar with service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_USER=info@programming-car.com
GOOGLE_CALENDAR_ID=primary
